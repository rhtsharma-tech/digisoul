{
  "expo": {
    "name": "DigiSoul",
    "slug": "digisoul",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06070A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digisoul.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06070A"
      },
      "package": "com.digisoul.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow DigiSoul to access your camera for QR code scanning."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A84C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
