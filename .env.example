# ===========================================
# DigiSoul Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# Vercel Deployment (Required for CI/CD)
# ===========================================
# Get these from https://vercel.com/account/tokens
VERCEL_TOKEN=

# Get these from https://vercel.com/dashboard/[project]/settings
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ===========================================
# Smart Contract Deployment
# ===========================================
# Private key for deploying contracts (DO NOT COMMIT)
PRIVATE_KEY=

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=

# ===========================================
# Application Configuration
# ===========================================
# RPC endpoint for Polygon Amoy testnet
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology

# Contract address (set after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=
