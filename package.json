{
  "name": "digisoul",
  "version": "0.1.0",
  "private": true,
  "description": "Secure Your Digital Legacy — Blockchain-based digital inheritance platform",
  "workspaces": [
    "packages/shared",
    "packages/contracts",
    "packages/web"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "test": "turbo test",
    "deploy:contracts": "cd packages/contracts && forge script script/Deploy.s.sol --broadcast --verify",
    "deploy:web": "cd packages/web && vercel --prod",
    "ci": "bash scripts/ci-local.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "tsc --noEmit --pretty"
    ]
  },
  "devDependencies": {
    "caniuse-lite": "^1.0.30001690",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.0",
    "postcss-nested": "^6.0.0",
    "postcss-selector-parser": "^6.0.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
